# Required: Google Sheet ID from the sheet URL.
ESTUDIO_ABIERTO_SHEET_ID=

# Optional: defaults to Leads if unset.
ESTUDIO_ABIERTO_SHEET_NAME=Leads

# Option A: full service account JSON key.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Option B: split service account client_email and private_key.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
